<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Insumos | Tacos El Pepe</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0">Insumos</h4>
            <a href="/insumos/nuevo" class="btn btn-dark">
                <i class="bi bi-plus-lg"></i> Nuevo insumo
            </a>
        </div>

        <%- include('../partials/flash') %>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Nombre</th>
                            <th>Unidad</th>
                            <th>Stock actual</th>
                            <th>Stock mínimo</th>
                            <th>Costo unitario</th>
                            <th>Proveedor</th>
                            <th>Estado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (insumos.length === 0) { %>
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">No hay insumos registrados.</td>
                        </tr>
                        <% } %>
                        <% insumos.forEach(i => { %>
                        <%
                            const stockCritico = parseFloat(i.stock_actual) <= parseFloat(i.stock_minimo);
                        %>
                        <tr class="<%= stockCritico ? 'table-warning' : '' %>">
                            <td>
                                <%= i.nombre %>
                                <% if (stockCritico) { %>
                                <span class="badge bg-warning text-dark ms-1">
                                    <i class="bi bi-exclamation-triangle"></i> Stock bajo
                                </span>
                                <% } %>
                            </td>
                            <td><%= i.unidad_medida %></td>
                            <td><%= parseFloat(i.stock_actual).toFixed(2) %></td>
                            <td><%= parseFloat(i.stock_minimo).toFixed(2) %></td>
                            <td>Q<%= parseFloat(i.costo_unitario).toFixed(4) %></td>
                            <td><%= i.proveedor %></td>
                            <td>
                                <% if (i.activo) { %>
                                <span class="badge bg-success">Activo</span>
                                <% } else { %>
                                <span class="badge bg-secondary">Inactivo</span>
                                <% } %>
                            </td>
                            <td>
                                <a href="/insumos/<%= i.id_insumo %>/editar" class="btn btn-sm btn-outline-secondary me-1">
                                    <i class="bi bi-pencil"></i> Editar
                                </a>
                                <form action="/insumos/<%= i.id_insumo %>?_method=DELETE" method="POST" class="d-inline"
                                      onsubmit="return confirm('¿Eliminar el insumo «<%= i.nombre %>»?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i> Eliminar
                                    </button>
                                </form>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
        <p class="text-muted mt-2 small">Total: <%= insumos.length %> insumo(s)</p>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
