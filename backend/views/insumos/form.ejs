<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= insumo ? 'Editar' : 'Nuevo' %> Insumo | Tacos El Pepe</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container mt-4">
        <div class="row justify-content-center">
            <div class="col-md-7">
                <div class="d-flex align-items-center mb-3">
                    <a href="/insumos" class="btn btn-sm btn-outline-secondary me-2">
                        <i class="bi bi-arrow-left"></i> Volver
                    </a>
                    <h4 class="mb-0"><%= insumo ? 'Editar insumo' : 'Nuevo insumo' %></h4>
                </div>

                <%- include('../partials/flash') %>

                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <% const action = insumo
                            ? `/insumos/${insumo.id_insumo}?_method=PUT`
                            : '/insumos'; %>
                        <form action="<%= action %>" method="POST">

                            <div class="mb-3">
                                <label for="nombre" class="form-label">Nombre <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="nombre" name="nombre"
                                       value="<%= insumo ? insumo.nombre : '' %>" required maxlength="150">
                            </div>

                            <div class="mb-3">
                                <label for="id_proveedor" class="form-label">Proveedor <span class="text-danger">*</span></label>
                                <select class="form-select" id="id_proveedor" name="id_proveedor" required>
                                    <option value="">Selecciona un proveedor</option>
                                    <% proveedores.forEach(p => { %>
                                    <option value="<%= p.id_proveedor %>"
                                        <%= insumo && insumo.id_proveedor == p.id_proveedor ? 'selected' : '' %>>
                                        <%= p.nombre %>
                                    </option>
                                    <% }) %>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label for="unidad_medida" class="form-label">Unidad de medida <span class="text-danger">*</span></label>
                                <select class="form-select" id="unidad_medida" name="unidad_medida" required>
                                    <option value="">Selecciona</option>
                                    <% ['gramo', 'ml', 'kg', 'litro', 'unidad'].forEach(u => { %>
                                    <option value="<%= u %>"
                                        <%= insumo && insumo.unidad_medida === u ? 'selected' : '' %>>
                                        <%= u %>
                                    </option>
                                    <% }) %>
                                </select>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="stock_actual" class="form-label">Stock actual</label>
                                    <input type="number" class="form-control" id="stock_actual" name="stock_actual"
                                           value="<%= insumo ? insumo.stock_actual : '0' %>"
                                           step="0.001" min="0">
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="stock_minimo" class="form-label">Stock mínimo</label>
                                    <input type="number" class="form-control" id="stock_minimo" name="stock_minimo"
                                           value="<%= insumo ? insumo.stock_minimo : '0' %>"
                                           step="0.001" min="0">
                                </div>
                            </div>

                            <div class="mb-4">
                                <label for="costo_unitario" class="form-label">Costo unitario (Q)</label>
                                <input type="number" class="form-control" id="costo_unitario" name="costo_unitario"
                                       value="<%= insumo ? insumo.costo_unitario : '0' %>"
                                       step="0.0001" min="0">
                            </div>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-dark">
                                    <i class="bi bi-check-lg"></i> <%= insumo ? 'Guardar cambios' : 'Crear insumo' %>
                                </button>
                                <a href="/insumos" class="btn btn-outline-secondary">Cancelar</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
