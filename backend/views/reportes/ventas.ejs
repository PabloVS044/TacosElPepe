<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Productos más vendidos | Tacos El Pepe</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h4 class="mb-0">Productos más vendidos</h4>
                <small class="text-muted">Excluye pedidos cancelados. Ordenado por ingresos totales.</small>
            </div>
            <a href="/reportes/diario" class="btn btn-outline-dark btn-sm">
                <i class="bi bi-calendar3"></i> Ver ventas diarias
            </a>
        </div>

        <%- include('../partials/flash') %>

        <% if (datos.length === 0) { %>
        <div class="alert alert-info">No hay datos de ventas disponibles todavía.</div>
        <% } else { %>

        <%
            const totalIngresos = datos.reduce((sum, d) => sum + parseFloat(d.ingresos_totales), 0);
        %>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Producto</th>
                            <th>Categoría</th>
                            <th>Precio unitario</th>
                            <th>Unidades vendidas</th>
                            <th>Ingresos totales</th>
                            <th>% del total</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% datos.forEach((d, idx) => { %>
                        <%
                            const pct = totalIngresos > 0
                                ? ((parseFloat(d.ingresos_totales) / totalIngresos) * 100).toFixed(1)
                                : '0.0';
                        %>
                        <tr>
                            <td class="text-muted"><%= idx + 1 %></td>
                            <td class="fw-semibold"><%= d.producto %></td>
                            <td><span class="badge bg-secondary"><%= d.categoria %></span></td>
                            <td>Q<%= parseFloat(d.precio_unitario).toFixed(2) %></td>
                            <td><%= d.unidades_vendidas %></td>
                            <td class="fw-semibold">Q<%= parseFloat(d.ingresos_totales).toFixed(2) %></td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height: 6px;">
                                        <div class="progress-bar bg-dark" style="width: <%= pct %>%"></div>
                                    </div>
                                    <small><%= pct %>%</small>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="5" class="fw-bold text-end">Total</td>
                            <td class="fw-bold">Q<%= totalIngresos.toFixed(2) %></td>
                            <td>100%</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
        <p class="text-muted mt-2 small"><%= datos.length %> producto(s) con ventas registradas.</p>
        <% } %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
