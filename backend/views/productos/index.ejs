<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Productos | Tacos El Pepe</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0">Productos</h4>
            <a href="/productos/nuevo" class="btn btn-dark">
                <i class="bi bi-plus-lg"></i> Nuevo producto
            </a>
        </div>

        <%- include('../partials/flash') %>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Nombre</th>
                            <th>Categoría</th>
                            <th>Precio</th>
                            <th>Tipo</th>
                            <th>Disponible</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (productos.length === 0) { %>
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">No hay productos registrados.</td>
                        </tr>
                        <% } %>
                        <% productos.forEach(p => { %>
                        <tr>
                            <td>
                                <%= p.nombre %>
                                <% if (p.descripcion) { %>
                                <small class="d-block text-muted"><%= p.descripcion.substring(0, 50) %><%= p.descripcion.length > 50 ? '...' : '' %></small>
                                <% } %>
                            </td>
                            <td><%= p.categoria %></td>
                            <td>Q<%= parseFloat(p.precio).toFixed(2) %></td>
                            <td>
                                <% if (p.es_combo) { %>
                                <span class="badge bg-info text-dark">Combo</span>
                                <% } else { %>
                                <span class="badge bg-secondary">Producto</span>
                                <% } %>
                            </td>
                            <td>
                                <% if (p.disponible) { %>
                                <span class="badge bg-success">Sí</span>
                                <% } else { %>
                                <span class="badge bg-danger">No</span>
                                <% } %>
                            </td>
                            <td>
                                <a href="/productos/<%= p.id_producto %>/editar" class="btn btn-sm btn-outline-secondary me-1">
                                    <i class="bi bi-pencil"></i> Editar
                                </a>
                                <form action="/productos/<%= p.id_producto %>?_method=DELETE" method="POST" class="d-inline"
                                      onsubmit="return confirm('¿Eliminar el producto «<%= p.nombre %>»?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i> Eliminar
                                    </button>
                                </form>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
        <p class="text-muted mt-2 small">Total: <%= productos.length %> producto(s)</p>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
