<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= producto ? 'Editar' : 'Nuevo' %> Producto | Tacos El Pepe</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <div class="container mt-4">
        <div class="row justify-content-center">
            <div class="col-md-7">
                <div class="d-flex align-items-center mb-3">
                    <a href="/productos" class="btn btn-sm btn-outline-secondary me-2">
                        <i class="bi bi-arrow-left"></i> Volver
                    </a>
                    <h4 class="mb-0"><%= producto ? 'Editar producto' : 'Nuevo producto' %></h4>
                </div>

                <%- include('../partials/flash') %>

                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">
                        <% const action = producto
                            ? `/productos/${producto.id_producto}?_method=PUT`
                            : '/productos'; %>
                        <form action="<%= action %>" method="POST" novalidate>

                            <div class="mb-3">
                                <label for="nombre" class="form-label">Nombre <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="nombre" name="nombre"
                                       value="<%= producto ? producto.nombre : '' %>" required maxlength="150">
                            </div>

                            <div class="mb-3">
                                <label for="id_categoria_producto" class="form-label">Categoría <span class="text-danger">*</span></label>
                                <select class="form-select" id="id_categoria_producto" name="id_categoria_producto" required>
                                    <option value="">Selecciona una categoría</option>
                                    <% categorias.forEach(cat => { %>
                                    <option value="<%= cat.id_categoria_producto %>"
                                        <%= producto && producto.id_categoria_producto == cat.id_categoria_producto ? 'selected' : '' %>>
                                        <%= cat.nombre %>
                                    </option>
                                    <% }) %>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label for="precio" class="form-label">Precio (Q) <span class="text-danger">*</span></label>
                                <input type="number" class="form-control" id="precio" name="precio"
                                       value="<%= producto ? producto.precio : '' %>"
                                       step="0.01" min="0" required>
                            </div>

                            <div class="mb-3">
                                <label for="descripcion" class="form-label">Descripción</label>
                                <textarea class="form-control" id="descripcion" name="descripcion"
                                          rows="2" maxlength="500"><%= producto ? producto.descripcion || '' : '' %></textarea>
                            </div>

                            <div class="mb-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="disponible" name="disponible"
                                           <%= !producto || producto.disponible ? 'checked' : '' %>>
                                    <label class="form-check-label" for="disponible">Disponible en el menú</label>
                                </div>
                            </div>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-dark">
                                    <i class="bi bi-check-lg"></i> <%= producto ? 'Guardar cambios' : 'Crear producto' %>
                                </button>
                                <a href="/productos" class="btn btn-outline-secondary">Cancelar</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
